                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
       (YEAR(fecha)*10000 + MONTH(fecha)*100 + DAY(fecha)) AS id_tiempo,
       id_cliente,
       id_tipo_de_precio,
       id_producto,
       ISNULL(id_promocion, 0) AS id_promocion,
       cantidad_vendida,
       precio_aplicado,
       monto_total,
       tipo_precio_aplicado
   FROM dbo.StgVentaDetalle;</property>
