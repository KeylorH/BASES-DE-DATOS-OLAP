          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{76D7ED78-7E6E-4E2A-A1EC-06EBBCFF427F}"
              SQLTask:SqlStatementSource="DECLARE @from BINARY(10), @to BINARY(10);&#xA;&#xA; SELECT @from = sys.fn_cdc_increment_lsn(last_lsn)&#xA; FROM Catwalk_Glowing_DW.dbo.cdc_state&#xA; WHERE table_name = 'Venta';&#xA;&#xA; SET @to = sys.fn_cdc_get_max_lsn();&#xA;&#xA; SELECT &#xA;     CONVERT(VARCHAR(22), @from, 1) AS from_lsn,&#xA;     CONVERT(VARCHAR(22), @to,   1) AS to_lsn;"
              SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ResultBinding
                SQLTask:ResultName="from_lsn"
                SQLTask:DtsVariableName="User::FromLSN_Venta" />
              <SQLTask:ResultBinding
                SQLTask:ResultName="to_lsn"
                SQLTask:DtsVariableName="User::ToLSN_Venta" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
