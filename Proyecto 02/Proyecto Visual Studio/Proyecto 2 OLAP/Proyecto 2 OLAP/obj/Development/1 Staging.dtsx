DECLARE @to   BINARY(10) = CONVERT(BINARY(10), @to_str,   1);

SELECT 
    p.id_producto,
    p.nombre   AS nombre_producto,
    cat.nombre AS categoria,
    m.nombre   AS marca
FROM cdc.fn_cdc_get_all_changes_dbo_Producto(@from, @to, 'all') c
INNER JOIN dbo.Producto  p   ON p.id_producto  = c.id_producto
INNER JOIN dbo.Categoria cat ON cat.id_categoria = p.id_categoria
INNER JOIN dbo.Marca     m   ON m.id_marca      = p.id_marca
WHERE c.__$operation = 2;</property>
