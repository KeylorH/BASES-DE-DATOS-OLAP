      DTS:ObjectName="Venta CDC Staging"
      DTS:TaskContact="Performs high-performance data extraction, transformation and loading;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
      <DTS:Variables />
      <DTS:ObjectData>
        <pipeline
          version="1">
          <components>
            <component
              refId="Package\Venta CDC Staging\CDC Venta"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="CDC Venta"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">DECLARE @from_str VARCHAR(22) = ?;
DECLARE @to_str   VARCHAR(22) = ?;
DECLARE @from BINARY(10) = CONVERT(BINARY(10), @from_str, 1);
DECLARE @to   BINARY(10) = CONVERT(BINARY(10), @to_str,   1);

WITH PrecioTipos AS (
    SELECT 
        ROW_NUMBER() OVER (
            ORDER BY precio_detalle, ISNULL(precio_mayorista, 0)
        ) AS id_tipo_de_precio,
        precio_detalle,
        precio_mayorista
    FROM (
        SELECT DISTINCT precio_detalle, precio_mayorista
        FROM dbo.Producto
    ) x
)
SELECT 
    v.id_venta,
    dv.id_detalle,
    v.fecha,
    v.id_cliente,
    dv.id_producto,
    ISNULL(dv.id_promocion, 0) AS id_promocion,
    pt.id_tipo_de_precio,
    dv.cantidad                AS cantidad_vendida,
    dv.precio_venta_unidad     AS precio_aplicado,
    (dv.cantidad * dv.precio_venta_unidad) AS monto_total,
    dv.tipo_precio             AS tipo_precio_aplicado
FROM cdc.fn_cdc_get_all_changes_dbo_Venta(@from, @to, 'all') c
INNER JOIN dbo.Venta        v  ON v.id_venta    = c.id_venta
INNER JOIN dbo.DetalleVenta dv ON dv.id_venta   = v.id_venta
INNER JOIN dbo.Producto     p  ON p.id_producto = dv.id_producto
INNER JOIN PrecioTipos pt 
       ON pt.precio_detalle = p.precio_detalle 
      AND ISNULL(pt.precio_mayorista, -1) = ISNULL(p.precio_mayorista, -1)
WHERE c.__$operation = 2;</property>
