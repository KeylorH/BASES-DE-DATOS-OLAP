                      externalMetadataColumnId="Package\TipoDePrecio Staging\Tipo de Precio.Outputs[OLE DB Source Output].ExternalColumns[precio_mayorista]"
                      lineageId="Package\TipoDePrecio Staging\Tipo de Precio.Outputs[OLE DB Source Output].Columns[precio_mayorista]"
                      name="precio_mayorista"
